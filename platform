<!DOCTYPE html>
<html>
<head>
    <title>Student Skill Exchange</title>
    <link rel="stylesheet" href="platform.css">
    <style>
        body {
            font-family: Arial;
            background: #f2f2f2;
            margin: 0;
        }
        header {
            background: #255c98;
            color: white;
            padding: 15px;
            text-align: center;
        }
        .container {
            width: 80%;
            margin: auto;
            margin-top: 20px;
        }
        input, button {
            padding: 10px;
            margin: 5px;
        }
        .card {
            background: white;
            padding: 15px;
            margin: 10px 0;
            border-radius: 5px;
        }
    </style>
</head>
<body>

<header>
    <h1>🎓 Student Skill Exchange Platform</h1>
</header>

<div class="container">
    <div class="from-box">

    <h2>Add Your Skills</h2>
    <input type="text" id="name" placeholder="Your Name">
    <input type="text" id="teach" placeholder="Skill You Can Teach">
    <input type="text" id="learn" placeholder="Skill You Want to Learn">
    <button onclick="addSkill()">Add skill</button>

    </div>
<div class="from-box">
    <h2>Search Skills</h2>
    <input type="text" id="search" placeholder="Search skill...">
    <button onclick="searchSkill()">Search</button>
    <button onclick="displayAll()">Show All</button>


    <h2>All Students</h2>
    <div id="output"></div>

</div>

</body>
<script src="platform.js"></script>
</html>